# Copier en .env et renseigner les clés (ne jamais committer .env)

# --- Clés API (requises) ---
GLADIA_API_KEY=
OPENAI_API_KEY=
CARTESIA_API_KEY=

# --- Voix Cartesia (requise) ---
# ID d'une voix FRANÇAISE de ta bibliothèque Cartesia (modèle Sonic).
CARTESIA_VOICE_ID=

# --- Options (valeurs par défaut entre parenthèses) ---
GLADIA_REGION=eu-west          # eu-west | us-west  (eu-west)
OPENAI_MODEL=gpt-4o-mini       # (gpt-4o-mini)
CARTESIA_MODEL=sonic-3.5       # modèle Sonic  (sonic-3.5)
